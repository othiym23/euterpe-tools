def build_parser() -> argparse.ArgumentParser:
    """Build the argument parser."""
    p = argparse.ArgumentParser(
        prog="etp-anime",
        description="Interactive anime collection manager",
    )
    p.add_argument("--version", "-V", action="version", version=VERSION)

    source_group = p.add_mutually_exclusive_group(required=True)
    source_group.add_argument("--anidb", type=int, metavar="ID", help="AniDB anime ID")
    source_group.add_argument(
        "--tvdb", type=int, metavar="ID", help="TheTVDB series ID"
    )
    source_group.add_argument(
        "--triage",
        action="store_true",
        default=False,
        help="Triage mode: scan source dirs, group by series, process interactively",
    )

    p.add_argument("--file", type=Path, metavar="PATH", help="Single file mode")
    p.add_argument(
        "--source",
        type=Path,
        action="append",
        metavar="DIR",
        help="Source directory (repeatable; default: NAS download dirs)",
    )
    p.add_argument(
        "--dest",
        type=Path,
        metavar="DIR",
        default=DEFAULT_DEST_DIR,
        help=f"Destination base directory (default: {DEFAULT_DEST_DIR})",
    )
    p.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without copying",
    )
    p.add_argument(
        "--no-cache",
        action="store_true",
        help="Bypass API response cache",
    )
    p.add_argument("-v", "--verbose", action="store_true", help="Verbose output")
    return p


def fetch_anime_info(
    anidb_id: int | None = None,
    tvdb_id: int | None = None,
    no_cache: bool = False,
) -> AnimeInfo:
    """Fetch anime info by AniDB or TheTVDB ID.

    Exactly one of *anidb_id* or *tvdb_id* must be provided.
    """
    if anidb_id is not None:
        client = os.environ.get("ANIDB_CLIENT", "")
        clientver_str = os.environ.get("ANIDB_CLIENTVER", "")
        if not client or not clientver_str:
            print(
                "error: ANIDB_CLIENT and ANIDB_CLIENTVER environment "
                "variables are required for AniDB lookup",
                file=sys.stderr,
            )
            sys.exit(1)
        clientver = int(clientver_str)
        print(f"Fetching AniDB anime {anidb_id}...")
        return fetch_anidb_anime(anidb_id, client, clientver, no_cache=no_cache)
    elif tvdb_id is not None:
        api_key = os.environ.get("TVDB_API_KEY", "")
        if not api_key:
            print(
                "error: TVDB_API_KEY environment variable is required for TheTVDB lookup",
                file=sys.stderr,
            )
            sys.exit(1)
        print(f"Fetching TheTVDB series {tvdb_id}...")
        return fetch_tvdb_series(tvdb_id, api_key, no_cache=no_cache)
    else:
        raise ValueError("Either anidb_id or tvdb_id must be provided")


def _fetch_anime_info(args: argparse.Namespace) -> AnimeInfo:
    """Fetch anime info based on CLI args."""
    return fetch_anime_info(
        anidb_id=args.anidb, tvdb_id=args.tvdb, no_cache=args.no_cache
    )


def _confirm_anime_info(info: AnimeInfo) -> AnimeInfo:
    """Interactively confirm and edit anime metadata."""
    print("\nAnime metadata:")
    print(f"  Japanese title: {info.title_ja}")
    print(f"  English title:  {info.title_en}")
    print(f"  Year:           {info.year}")

    regular_eps = [e for e in info.episodes if e.ep_type == "regular"]
    special_eps = [e for e in info.episodes if e.ep_type != "regular"]
    print(f"  Episodes:       {len(regular_eps)} regular, {len(special_eps)} special")

    if not prompt_confirm("\nUse these values?"):
        info.title_ja = prompt_value("Japanese title", info.title_ja)
        info.title_en = prompt_value("English title", info.title_en)
        year_str = prompt_value("Year", str(info.year))
        info.year = int(year_str) if year_str.isdigit() else info.year

    return info


_RE_NON_ALNUM = re.compile(r"[^a-z0-9]")


def _strip_series_name(stem: str) -> str:
    """Strip release metadata from a filename stem to get a series name."""
    name = _RE_LEADING_GROUP.sub("", stem)
    name = _RE_TRAILING_HASH.sub("", name)
    name = _RE_EPISODE_SUFFIX.sub("", name)
    name = _RE_S_E_SUFFIX.sub("", name)
    name = _RE_DOT_S_E.sub("", name)
    name = _RE_DASH_EP_END.sub("", name)
    return name.strip(" -")


def _extract_series_name(filename: str) -> str:
    """Extract a candidate series name from a single filename for grouping."""
    return _strip_series_name(Path(filename).stem)


def _normalize_for_grouping(name: str) -> str:
    """Normalize a series name for grouping: lowercase, strip non-alnum."""
    return _RE_NON_ALNUM.sub("", name.lower())


def _extract_concise_name(source_files: list[SourceFile]) -> str:
    """Try to extract a concise series name from source filenames."""
    if not source_files:
        return ""
    return _strip_series_name(source_files[0].path.stem)


def _process_file(
    source: SourceFile,
    info: AnimeInfo,
    concise_name: str,
    series_dir: Path,
    dry_run: bool,
    verbose: bool,
) -> bool:
    """Process a single source file: analyze, name, copy."""
    print(f"\n--- {source.path.name} ---")

    # Analyze with mediainfo
    try:
        source.media = analyze_file(source.path)
        if verbose:
            m = source.media
            print(
                f"  Video: {m.video_codec} {m.resolution} "
                f"{m.bit_depth}bit {m.hdr_type or 'SDR'}"
            )
            print(f"  Encoding lib: {m.encoding_lib or '(none)'}")
            for t in m.audio_tracks:
                commentary = " (commentary)" if t.is_commentary else ""
                print(f"  Audio: {t.codec} [{t.language}] {t.title}{commentary}")
    except (subprocess.CalledProcessError, FileNotFoundError) as e:
        print(f"  warning: mediainfo failed: {e}")
        print("  Skipping this file.")
        return False

    # Determine episode type and number
    ep_number = source.parsed_episode
    season = source.parsed_season or 1
    is_special = False
    special_tag = ""
    episode_name = ""

    if ep_number is not None:
        # Try to match to an episode in the anime info
        for ep in info.episodes:
            if ep.ep_type == "regular" and ep.number == ep_number:
                episode_name = ep.title_en
                break
    else:
        # Ask for episode number
        ep_str = prompt_value("Episode number (or special tag like S1, NCOP1)")
        # Check if it's a special tag
        if re.match(r"^[A-Z]", ep_str):
            is_special = True
            special_tag = ep_str
            # Try to find matching episode
            for ep in info.episodes:
                if ep.special_tag == ep_str:
                    episode_name = ep.title_en
                    break
        else:
            try:
                ep_number = int(ep_str)
            except ValueError:
                print("  Invalid episode number, skipping.")
                return False

    # Confirm episode assignment
    if ep_number is not None and not is_special:
        ep_display = f"s{season}e{ep_number:02d}"
        if episode_name:
            ep_display += f" - {episode_name}"
        confirmed = prompt_value("Episode", ep_display)
        if confirmed != ep_display:
            # Re-parse if edited
            m = re.match(r"s(\d+)e(\d+)(?:\s*-\s*(.*))?", confirmed, re.IGNORECASE)
            if m:
                season = int(m.group(1))
                ep_number = int(m.group(2))
                episode_name = (m.group(3) or "").strip()

    # Build filename
    filename = format_episode_filename(
        concise_name=concise_name,
        season=season,
        episode=ep_number or 0,
        episode_name=episode_name,
        source=source,
        is_special=is_special,
        special_tag=special_tag,
    )

    # Determine destination
    if is_special:
        dest_dir = series_dir / "Specials"
    else:
        dest_dir = series_dir / f"Season {season:02d}"

    dest_path = dest_dir / filename
    print(f"\n  -> {dest_path}")

    if not prompt_confirm("  Copy this file?"):
        return False

    return copy_reflink(source.path, dest_path, dry_run=dry_run)


def _process_group(
    files: list[Path],
    info: AnimeInfo,
    id_map: dict[tuple[str, int], Path],
    dest: Path,
    dry_run: bool,
    verbose: bool,
    default_concise_name: str = "",
) -> tuple[int, int]:
    """Parse, resolve directory, and process a group of files.

    Returns ``(success_count, failed_count)``.
    """
    parsed: list[SourceFile] = []
    for f in files:
        sf = parse_source_filename(f.name)
        sf.path = f
        parsed.append(sf)

    if not default_concise_name:
        default_concise_name = _extract_concise_name(parsed)
    concise_name = prompt_value("Concise series name for filenames", default_concise_name)

    has_specials = any(e.ep_type != "regular" for e in info.episodes)
    seasons_needed = {sf.parsed_season or 1 for sf in parsed}
    seasons_list = sorted(seasons_needed)

    series_dir = resolve_series_directory(
        dest, info, id_map=id_map,
        seasons=seasons_list, has_specials=has_specials, dry_run=dry_run,
    )
    print(f"\nSeries directory: {series_dir}")

    # Update id_map so callers see this directory
    if info.anidb_id is not None:
        id_map[("anidb", info.anidb_id)] = series_dir
    if info.tvdb_id is not None:
        id_map[("tvdb", info.tvdb_id)] = series_dir

    success = 0
    failed = 0
    for sf in parsed:
        if _process_file(sf, info, concise_name, series_dir, dry_run, verbose):
            success += 1
        else:
            failed += 1
    return success, failed


def run_per_series(args: argparse.Namespace) -> int:
    """Run the per-series interactive workflow."""
    info = _fetch_anime_info(args)
    info = _confirm_anime_info(info)

    # Scan destination for existing series
    id_map = scan_dest_ids(args.dest)

    # Determine source directories
    source_dirs = args.source or DEFAULT_SOURCE_DIRS

    # Search for source files
    search = prompt_value(
        "Search term for source files", info.title_en or info.title_ja
    )
    source_files = find_source_files(source_dirs, search)

    if not source_files:
        print("\nNo matching files found in source directories.")
        manual = prompt_value("Enter a path to search (or 'q' to quit)", "")
        if not manual or manual == "q":
            return 0
        source_files = find_source_files([Path(manual)], search)

    if not source_files:
        print("No files found. Exiting.")
        return 0

    # Display found files
    print(f"\nFound {len(source_files)} file(s):")
    for i, f in enumerate(source_files, 1):
        print(f"  {i}) {f.name}")
        if args.verbose:
            print(f"     {f}")

    # Select files to process
    if not prompt_confirm(f"\nProcess all {len(source_files)} files?"):
        selection = prompt_value(
            "Enter file numbers to process (comma-separated, e.g. 1,3,5)"
        )
        try:
            indices = [int(x.strip()) - 1 for x in selection.split(",")]
            source_files = [source_files[i] for i in indices]
        except (ValueError, IndexError):
            print("Invalid selection. Exiting.")
            return 1

    success, failed = _process_group(
        source_files, info, id_map, args.dest, args.dry_run, args.verbose
    )
    print(f"\nDone: {success} copied, {failed} skipped/failed")
    return 0 if failed == 0 else 1


def run_single_file(args: argparse.Namespace) -> int:
    """Run the single-file workflow."""
    if not args.file.is_file():
        print(f"error: {args.file} is not a file", file=sys.stderr)
        return 1

    info = _fetch_anime_info(args)
    info = _confirm_anime_info(info)

    # Scan destination for existing series
    id_map = scan_dest_ids(args.dest)

    # Parse the source file
    sf = parse_source_filename(args.file.name)
    sf.path = args.file

    # Get concise name
    default_name = _extract_concise_name([sf])
    concise_name = prompt_value("Concise series name for filename", default_name)

    # Resolve or create series directory
    has_specials = any(e.ep_type != "regular" for e in info.episodes)
    series_dir = resolve_series_directory(
        args.dest,
        info,
        id_map=id_map,
        has_specials=has_specials,
        dry_run=args.dry_run,
    )
    print(f"\nSeries directory: {series_dir}")

    if _process_file(sf, info, concise_name, series_dir, args.dry_run, args.verbose):
        print("\nDone: 1 file copied")
        return 0
    else:
        print("\nDone: file skipped/failed")
        return 1


def run_triage(args: argparse.Namespace) -> int:
    """Run the triage workflow: scan, group, prompt per group."""
    source_dirs = args.source or DEFAULT_SOURCE_DIRS
    groups = _scan_and_group(source_dirs)

    if not groups:
        print("No media files found in source directories.")
        return 0

    # Scan destination for existing series (once, reused across groups)
    id_map = scan_dest_ids(args.dest)

    print(f"\nFound {len(groups)} group(s):")
    group_list = list(groups.items())
    for i, (name, files) in enumerate(group_list, 1):
        count = len(files)
        print(f"  {i}) {name}  ({count} file{'s' if count != 1 else ''})")

    # Process each group
    total_success = 0
    total_failed = 0
    groups_processed = 0

    for name, files in group_list:
        print(f"\n{'='*60}")
        print(f"Group: {name}  ({len(files)} files)")
        print(f"{'='*60}")
        for f in files:
            print(f"  {f.name}")

        raw = input("\nAniDB ID, TheTVDB ID (prefix with 't'), or 's' to skip: ").strip()
        if not raw or raw.lower() == "s":
            print("  Skipping group.")
            continue

        # Parse the ID
        anidb_id: int | None = None
        tvdb_id: int | None = None
        try:
            if raw.lower().startswith("t"):
                tvdb_id = int(raw[1:])
            else:
                anidb_id = int(raw)
        except ValueError:
            print(f"  Invalid ID '{raw}', skipping group.")
            continue

        # Fetch metadata
        try:
            info = fetch_anime_info(
                anidb_id=anidb_id, tvdb_id=tvdb_id, no_cache=args.no_cache
            )
        except Exception as e:
            print(f"  Error fetching metadata: {e}")
            continue

        info = _confirm_anime_info(info)

        success, failed = _process_group(
            files, info, id_map, args.dest, args.dry_run, args.verbose,
            default_concise_name=name,
        )
        print(f"\n  Group done: {success} copied, {failed} skipped/failed")
        total_success += success
        total_failed += failed
        groups_processed += 1

    print(f"\n{'='*60}")
    print(
        f"Triage complete: {groups_processed} groups processed, "
        f"{total_success} files copied, {total_failed} skipped/failed"
    )
    return 0 if total_failed == 0 else 1


def main() -> int:
    """Entry point."""
    parser = build_parser()
    args = parser.parse_args()

    if not shutil.which("mediainfo"):
        print(
            "error: mediainfo not found on $PATH. Install it to analyze media files.",
            file=sys.stderr,
        )
        return 1

    if args.triage:
        return run_triage(args)
    elif args.file:
        return run_single_file(args)
    else:
        return run_per_series(args)


if __name__ == "__main__":
    sys.exit(main())
