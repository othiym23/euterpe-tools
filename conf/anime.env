# Sample API credentials for `etp anime` (etp-anime).
#
# Place this file at:
#   Linux / NAS: ~/.config/euterpe-tools/anime.env
#   macOS:       ~/Library/Application Support/net.aoaioxxysz.etp/anime.env
#
# Simple KEY=VALUE lines; no quoting, no interpolation. Lines starting
# with # are ignored. Values already present in the process environment
# are never overwritten.

# AniDB HTTP API client registration (https://anidb.net/software/add)
ANIDB_CLIENT=yourclientname
ANIDB_CLIENTVER=1

# TheTVDB v4 API key (https://thetvdb.com/api-information)
TVDB_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
