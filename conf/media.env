# Sample API credentials for `etp movies` and `etp television`.
#
# Place this file at:
#   Linux / NAS: ~/.config/euterpe-tools/media.env
#   macOS:       ~/Library/Application Support/net.aoaioxxysz.etp/media.env
#
# Simple KEY=VALUE lines; no quoting, no interpolation. Lines starting
# with # are ignored. Values already present in the process environment
# are never overwritten. anime.env is read as a fallback, so a
# TVDB_API_KEY already configured there keeps working if omitted here.

# TMDB API credentials (https://www.themoviedb.org/settings/api).
# Either a v3 API key or a v4 read-access token (the long "ey..." JWT)
# works — the client sends whichever form it recognizes.
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TheTVDB v4 API key (https://thetvdb.com/api-information)
TVDB_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
