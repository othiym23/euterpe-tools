{
  "statusLine": {
    "type": "command",
    "command": "bash .devcontainer/statusline-shim.sh",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "_tag": "ccstatusline-managed",
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .devcontainer/statusline-shim.sh --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [
          {
            "type": "command",
            "command": "bash .devcontainer/statusline-shim.sh --hook"
          }
        ]
      }
    ]
  }
}
